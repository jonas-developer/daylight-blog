<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - Gunnels Blogg</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { 
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; 
      background: linear-gradient(145deg, #1a3a1c 0%, #2d5a27 50%, #1e4620 100%);
      min-height: 100vh;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-container {
      background: white;
      padding: 3rem;
      border-radius: 20px;
      box-shadow: 0 25px 80px rgba(0,0,0,0.4);
      width: 100%;
      max-width: 420px;
      text-align: center;
      margin: 1rem;
    }
    .login-logo {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
    }
    .login-title {
      color: #1a3a1c;
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    .login-subtitle {
      color: #666;
      margin-bottom: 2rem;
      font-size: 0.95rem;
    }
    .error-message {
      background: linear-gradient(to right, #fee, #ffebee);
      color: #c62828;
      padding: 0.875rem;
      border-radius: 10px;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
      border-left: 4px solid #c62828;
    }
    .form-group {
      margin-bottom: 1.25rem;
      text-align: left;
    }
    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      color: #333;
      font-weight: 600;
      font-size: 0.9rem;
    }
    .form-group input {
      width: 100%;
      padding: 0.9rem 1rem;
      border: 2px solid #e0e0e0;
      border-radius: 10px;
      font-size: 1rem;
      transition: all 0.25s ease;
    }
    .form-group input:focus {
      outline: none;
      border-color: #2d5a27;
      box-shadow: 0 0 0 4px rgba(45, 90, 39, 0.15);
    }
    .btn-primary {
      width: 100%;
      padding: 1rem;
      background: linear-gradient(135deg, #4a9c3d 0%, #2d5a27 50%, #1e4620 100%);
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 1.05rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      margin-top: 0.5rem;
      box-shadow: 0 4px 15px rgba(45, 90, 39, 0.3);
    }
    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 35px rgba(45, 90, 39, 0.45);
      background: linear-gradient(135deg, #5aac4d 0%, #3d7a37 50%, #2d5a27 100%);
    }
    .btn-primary:active {
      transform: translateY(-1px);
    }
    .back-link {
      display: block;
      margin-top: 1.75rem;
      color: #666;
      text-decoration: none;
      font-size: 0.9rem;
      transition: color 0.2s;
    }
    .back-link:hover {
      color: #2d5a27;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="login-logo">🌿</div>
    <h1 class="login-title">Admin Login</h1>
    <p class="login-subtitle">Sign in to manage your blog</p>
    
    <% if (error) { %>
    <div class="error-message">
      <%= error %>
    </div>
    <% } %>
    
    <form method="POST" action="/login">
      <div class="form-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required placeholder="Enter your username">
      </div>
      
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required placeholder="Enter your password">
      </div>
      
      <button type="submit" class="btn-primary">Sign In</button>
    </form>
    
    <a href="/" class="back-link">← Back to website</a>
  </div>
</body>
</html>
