<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>☀️</text></svg>">
  <style>
    body { min-height: 100vh; margin: 0; }
    .page-wrapper {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .main-content {
      flex: 1;
      padding: 40px 20px;
      max-width: 600px;
      margin: 0 auto;
      width: 100%;
      box-sizing: border-box;
    }
    .form-card {
      background: #ffffff;
      border: 1px solid #e5e5e5;
      border-radius: 12px;
      padding: 30px;
    }
    .header {
      text-align: center;
      margin-bottom: 30px;
    }
    .logo {
      font-family: 'Great Vibes', 'Allura', 'Parisienne', cursive;
      font-size: 3rem;
      color: #2d5a27;
      margin: 0;
      font-weight: 400;
    }
    .form-group {
      margin-bottom: 20px;
    }
    label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      color: #333;
    }
    select {
      width: 100%;
      padding: 12px;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-size: 1rem;
      background: white;
    }
    .btn {
      display: inline-block;
      padding: 14px 28px;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s;
      text-decoration: none;
    }
    .btn:hover {
      opacity: 0.9;
    }
    .btn-primary {
      background: linear-gradient(135deg, #4a9c3d 0%, #2d5a27 100%);
      color: white;
      width: 100%;
      text-align: center;
      box-sizing: border-box;
    }
    .btn-secondary {
      background: #f5f5f5;
      color: #333;
      margin-top: 10px;
      width: 100%;
      text-align: center;
      box-sizing: border-box;
    }
    .btn-back {
      background: transparent;
      color: #4a9c3d;
      margin-top: 20px;
      text-align: center;
      display: block;
    }
    .message {
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 20px;
    }
    .message-success {
      background: #d4edda;
      color: #155724;
      border: 1px solid #c3e6cb;
    }
    .message-error {
      background: #f8d7da;
      color: #721c24;
      border: 1px solid #f5c6cb;
    }
    .subscriber-count {
      text-align: center;
      color: #666;
      margin-bottom: 20px;
      font-size: 0.9rem;
    }
    .post-preview {
      background: #f9f9f9;
      padding: 15px;
      border-radius: 8px;
      margin-top: 10px;
      font-size: 0.9rem;
      color: #666;
    }
    .post-preview strong {
      color: #333;
    }
  </style>
</head>
<body>
  <div class="page-wrapper">
    <main class="main-content">
      <div class="form-card">
        <div class="header">
          <h1 class="logo">Daylight Blog</h1>
          <p style="color: #666; margin-top: 10px;">Send Newsletter</p>
        </div>
        
        <% if (success) { %>
          <div class="message message-success"><%= success %></div>
        <% } %>
        
        <% if (error) { %>
          <div class="message message-error"><%= error %></div>
        <% } %>
        
        <p class="subscriber-count">
          📧 <strong><%= subscriberCount %></strong> active subscriber<%= subscriberCount !== 1 ? 's' : '' %>
        </p>
        
        <form id="newsletter-form" method="POST" action="/admin/send-newsletter">
          <div class="form-group">
            <label for="post_id">Select Post</label>
            <select name="post_id" id="post_id" required>
              <option value="">-- Choose a post --</option>
              <% posts.forEach(function(post) { %>
                <option value="<%= post.id %>">
                  <%= post.title %> (<%= new Date(post.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>)
                </option>
              <% }); %>
            </select>
          </div>
          
          <div id="post-preview" class="post-preview" style="display: none;">
            <strong>Post preview:</strong>
            <div id="preview-content"></div>
          </div>
          
          <button type="submit" name="test" value="0" class="btn btn-primary">
            📧 Send to Subscribers
          </button>
          
          <button type="submit" name="test" value="1" class="btn btn-secondary">
            🧪 Send to Yourself (Test)
          </button>
        </form>
        
        <a href="/admin" class="btn btn-back">← Back to Dashboard</a>
      </div>
    </main>
  </div>

  <script>
    const posts = <%- JSON.stringify(posts) %>;
    const postSelect = document.getElementById('post_id');
    const previewDiv = document.getElementById('post-preview');
    const previewContent = document.getElementById('preview-content');
    
    postSelect.addEventListener('change', function() {
      const postId = this.value;
      if (!postId) {
        previewDiv.style.display = 'none';
        return;
      }
      
      const post = posts.find(p => p.id == postId);
      if (post) {
        const content = post.content ? post.content.substring(0, 200) + (post.content.length > 200 ? '...' : '') : 'No content';
        previewContent.innerHTML = '<p>' + content.replace(/\n/g, '<br>') + '</p>';
        previewDiv.style.display = 'block';
      }
    });
  </script>
</body>
</html>
